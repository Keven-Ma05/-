/* recombiner.wxss - 文化基因重组器样式 */

.container {
  padding: 20rpx;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 顶部标题 */
.header-card {
  background: linear-gradient(135deg, #8B4513 0%, #D2B48C 50%, #C41E3A 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.25);
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

/* 选择区域 */
.selection-area {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  gap: 12rpx;
}

.select-box {
  flex: 1;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  min-height: 200rpx;
  border: 3rpx dashed #D2B48C;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.select-box.has-selected {
  border-style: solid;
  border-color: #8B4513;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFFDF5 100%);
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.12);
}

.select-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 2rpx;
}

.select-placeholder {
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.placeholder-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 8rpx;
}

.selected-element {
  text-align: center;
}

.selected-element .element-emoji {
  font-size: 64rpx;
  display: block;
  margin-bottom: 8rpx;
}

.selected-element .element-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #8B4513;
  margin-bottom: 6rpx;
}

.selected-element .element-desc {
  display: block;
  font-size: 20rpx;
  color: #666;
  line-height: 1.4;
}

/* 融合符号 */
.fusion-symbol {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
}

.fusion-x {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #C41E3A, #8B4513);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(196, 30, 58, 0.3);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

/* 元素选择网格 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #8B4513;
  margin-bottom: 20rpx;
}

.element-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.element-card {
  width: calc(50% - 8rpx);
  background-color: #FDF8F4;
  border-radius: 14rpx;
  padding: 20rpx 16rpx;
  position: relative;
  border: 3rpx solid transparent;
  transition: all 0.25s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.element-card:active {
  transform: scale(0.96);
}

.element-card.selected-a {
  border-color: #C41E3A;
  background: linear-gradient(135deg, #FFF0F3 0%, #FFF8F0 100%);
  box-shadow: 0 4rpx 16rpx rgba(196, 30, 58, 0.15);
}

.element-card.selected-b {
  border-color: #1E5FC4;
  background: linear-gradient(135deg, #F0F3FF 0%, #F8F0FF 100%);
  box-shadow: 0 4rpx 16rpx rgba(30, 95, 196, 0.15);
}

.element-tag {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  background-color: rgba(139, 69, 19, 0.1);
  color: #8B4513;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 20rpx;
}

.element-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 10rpx;
  text-align: center;
}

.element-card-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 6rpx;
}

.element-card-desc {
  display: block;
  font-size: 20rpx;
  color: #999;
  text-align: center;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.badge {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #FFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.badge-a {
  background: linear-gradient(135deg, #C41E3A, #E8505B);
}

.badge-b {
  background: linear-gradient(135deg, #1E5FC4, #4A90E2);
}

/* 操作区 */
.action-section {
  margin-bottom: 20rpx;
}

.select-hint {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
}

.recombine-btn {
  width: 100%;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  transition: all 0.3s ease;
  background: linear-gradient(135deg, #C41E3A 0%, #8B4513 100%);
  color: #FFFFFF;
}

.recombine-btn.disabled {
  background: #CCC;
  color: #999;
}

.recombine-btn:not(.disabled):active {
  transform: scale(0.97);
}

/* 融合过程可视化 */
.fusion-process {
  margin-bottom: 20rpx;
}

.fusion-card {
  background: linear-gradient(180deg, #1A0A2E 0%, #2D1B4E 50%, #1A0A2E 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(45, 27, 78, 0.3);
  position: relative;
  overflow: hidden;
}

.fusion-title {
  display: block;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFD700;
  margin-bottom: 30rpx;
}

/* 双元素融合动画 */
.fusion-visual {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  position: relative;
}

.fusion-elem {
  text-align: center;
  width: 140rpx;
}

.fusion-elem .fusion-emoji {
  font-size: 72rpx;
  display: block;
  margin-bottom: 8rpx;
  animation: floatUpDown 2s ease-in-out infinite;
}

.fusion-elem.left .fusion-emoji {
  animation-delay: 0s;
  color: #FF6B6B;
}

.fusion-elem.right .fusion-emoji {
  animation-delay: 0.5s;
  color: #4ECDC4;
}

.fusion-elem .fusion-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

@keyframes floatUpDown {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

/* 融合中心动画 */
.fusion-center {
  flex: 1;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.fusion-spiral {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  border-top-color: #FFD700;
  border-right-color: #FF6B6B;
  border-bottom-color: #4ECDC4;
  border-left-color: #FFD700;
  animation: spin 1.5s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.fusion-particle-container {
  position: absolute;
  width: 100%;
  height: 100%;
}

.particle {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  animation: particleFloat 1.5s ease-in-out infinite;
}

.particle.p1 { background: #FFD700; top: 20%; left: 30%; animation-delay: 0s; }
.particle.p2 { background: #FF6B6B; top: 60%; left: 50%; animation-delay: 0.3s; }
.particle.p3 { background: #4ECDC4; top: 30%; left: 70%; animation-delay: 0.6s; }
.particle.p4 { background: #FFD700; top: 70%; left: 40%; animation-delay: 0.9s; }
.particle.p5 { background: #FF6B6B; top: 40%; left: 20%; animation-delay: 1.2s; }
.particle.p6 { background: #4ECDC4; top: 50%; left: 60%; animation-delay: 0.15s; }

@keyframes particleFloat {
  0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.6; }
  50% { transform: translate(10rpx, -20rpx) scale(1.8); opacity: 1; }
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF6B6B, #FFD700, #4ECDC4);
  border-radius: 6rpx;
  transition: width 0.5s ease;
  position: relative;
}

.progress-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

.progress-percent {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #FFD700;
  margin-bottom: 8rpx;
}

.fusion-phase {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
}

/* DNA双螺旋装饰 */
.dna-helix {
  position: relative;
  height: 40rpx;
  overflow: hidden;
}

.dna-strand {
  position: absolute;
  width: 100%;
  height: 2rpx;
  top: 50%;
}

.dna-strand.s1 {
  background: linear-gradient(90deg, 
    transparent 0%, #FF6B6B 10%, transparent 20%,
    transparent 30%, #4ECDC4 40%, transparent 50%,
    transparent 60%, #FFD700 70%, transparent 80%,
    transparent 90%, #FF6B6B 100%
  );
  animation: dnaMove1 2s linear infinite;
}

.dna-strand.s2 {
  background: linear-gradient(90deg, 
    transparent 0%, #4ECDC4 10%, transparent 20%,
    transparent 30%, #FFD700 40%, transparent 50%,
    transparent 60%, #FF6B6B 70%, transparent 80%,
    transparent 90%, #4ECDC4 100%
  );
  animation: dnaMove2 2s linear infinite;
}

@keyframes dnaMove1 {
  from { transform: translateX(-100%); }
  to { transform: translateX(100%); }
}

@keyframes dnaMove2 {
  from { transform: translateX(100%); }
  to { transform: translateX(-100%); }
}

/* ===== 结果展示 ===== */
.result-card {
  position: relative;
  overflow: hidden;
}

.result-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #8B4513;
  text-align: center;
  margin-bottom: 20rpx;
}

.result-image-wrapper {
  position: relative;
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.result-image {
  width: 100%;
  min-height: 400rpx;
  background-color: #F5F5DC;
}

.result-watermark {
  position: absolute;
  bottom: 12rpx;
  right: 12rpx;
  background-color: rgba(0, 0, 0, 0.45);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.result-watermark text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
}

.result-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.7;
  text-align: center;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background-color: #FDF8F4;
  border-radius: 12rpx;
}

/* 基因对比条 */
.gene-compare {
  margin-bottom: 24rpx;
  padding: 16rpx;
  background-color: #FAFAFA;
  border-radius: 12rpx;
}

.gene-item {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.gene-item:last-child {
  margin-bottom: 0;
}

.gene-label {
  font-size: 24rpx;
  color: #333;
  width: 180rpx;
  flex-shrink: 0;
}

.gene-bar {
  height: 14rpx;
  border-radius: 7rpx;
  background: linear-gradient(90deg, #C41E3A, #E8A0A0);
  transition: width 0.8s ease;
  flex: 1;
}

.gene-bar.bar-b {
  background: linear-gradient(90deg, #1E5FC4, #A0C4E8);
}

.gene-bar.bar-fusion {
  background: linear-gradient(90deg, #C41E3A, #8B4513, #D2B48C, #1E5FC4);
  animation: gradientShift 3s ease-in-out infinite;
}

@keyframes gradientShift {
  0%, 100% { filter: hue-rotate(0deg); }
  50% { filter: hue-rotate(20deg); }
}

/* 操作按钮 */
.result-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.result-actions .btn {
  flex: 1;
  min-width: 160rpx;
  padding: 20rpx 16rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  text-align: center;
}

.full-width-btn {
  width: 100%;
  padding: 24rpx;
  font-size: 28rpx;
  border-radius: 14rpx;
}

/* ===== 历史记录 ===== */
.history-scroll {
  display: flex;
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.history-item {
  width: 160rpx;
  margin-right: 16rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #FDF8F4;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  display: inline-block;
  vertical-align: top;
}

.history-item:active {
  transform: scale(0.95);
}

.history-image {
  width: 160rpx;
  height: 160rpx;
}

.history-info {
  padding: 10rpx 12rpx;
}

.history-title {
  font-size: 22rpx;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.history-time {
  font-size: 18rpx;
  color: #999;
  display: block;
}

/* ===== 通用按钮 ===== */
.btn {
  display: inline-block;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.btn-primary {
  background-color: #8B4513;
  color: #FFFFFF;
}

.btn-secondary {
  background-color: #D2B48C;
  color: #FFFFFF;
}

.btn-outline {
  background-color: transparent;
  border: 2rpx solid #8B4513;
  color: #8B4513;
}
