/* community.wxss - 创作者社区样式 */

.container {
  width: 100%;
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 社区标签切换 */
.community-tabs {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
}

.tab-item {
  flex: 1;
  padding: 24rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-color);
  transition: all 0.3s ease;
}

.tab-item.active {
  background-color: var(--primary-color);
  color: #FFFFFF;
}

/* 作品列表 */
.works-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.work-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

/* 作者信息 */
.author-info {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.author-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.author-details {
  flex: 1;
}

.author-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-color);
  margin-bottom: 4rpx;
}

.post-time {
  display: block;
  font-size: 22rpx;
  color: var(--light-text);
}

.follow-btn,
.following-btn {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 20rpx;
  line-height: 1;
}

.follow-btn {
  background-color: var(--primary-color);
  color: #FFFFFF;
  border: none;
}

.following-btn {
  background-color: rgba(139, 69, 19, 0.1);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

/* 作品内容 */
.work-content {
  margin-bottom: 20rpx;
}

.work-image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.work-info {
  padding: 0 4rpx;
}

.work-title {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: var(--text-color);
  margin-bottom: 12rpx;
}

.work-description {
  display: block;
  font-size: 24rpx;
  color: var(--light-text);
  margin-bottom: 16rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.work-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background-color: rgba(139, 69, 19, 0.1);
  color: var(--primary-color);
  border-radius: 12rpx;
}

/* 作品操作 */
.work-actions {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 0;
  border-top: 1rpx solid var(--border-color);
  border-bottom: 1rpx solid var(--border-color);
  margin-bottom: 16rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx;
  transition: all 0.3s ease;
}

.action-item.active .action-icon {
  color: var(--error-color);
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  color: var(--light-text);
}

.action-count {
  font-size: 22rpx;
  color: var(--light-text);
}

/* 评论预览 */
.comments-preview {
  padding: 16rpx 0;
}

.comments-hint {
  display: block;
  font-size: 24rpx;
  color: var(--primary-color);
  margin-bottom: 12rpx;
}

.comment-item {
  display: flex;
  margin-bottom: 8rpx;
  font-size: 24rpx;
}

.comment-author {
  font-weight: 500;
  color: var(--text-color);
  margin-right: 8rpx;
}

.comment-content {
  color: var(--light-text);
}

/* 发布按钮 */
.publish-btn-container {
  position: fixed;
  bottom: 30rpx;
  right: 30rpx;
  z-index: 999;
}

.publish-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: var(--primary-color);
  color: #FFFFFF;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.4);
  transition: all 0.3s ease;
}

.publish-btn:active {
  transform: scale(0.95);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .work-item {
    padding: 16rpx;
  }
  
  .author-avatar {
    width: 60rpx;
    height: 60rpx;
  }
  
  .author-name {
    font-size: 26rpx;
  }
  
  .follow-btn,
  .following-btn {
    padding: 10rpx 20rpx;
    font-size: 22rpx;
  }
  
  .work-image {
    height: 300rpx;
  }
  
  .work-title {
    font-size: 28rpx;
  }
  
  .publish-btn {
    width: 100rpx;
    height: 100rpx;
    font-size: 50rpx;
  }
}