<!-- profile.wxml - 个人中心 -->
<view class="container">
  <!-- 用户信息 -->
  <view class="user-info-card">
    <image src="{{userInfo.avatarUrl || defaultAvatar}}" mode="aspectFill" class="user-avatar"></image>
    <view class="user-details">
      <text class="user-nickname">{{userInfo.nickName || '未登录'}}</text>
      <text class="user-id">ID: {{userInfo.openId || '未登录'}}</text>
    </view>
    <button class="login-btn" wx:if="{{!isLogin}}" bindtap="login">登录</button>
  </view>

  <!-- 统计信息 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-number">{{stats.works}}</text>
      <text class="stat-label">我的作品</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{stats.followings}}</text>
      <text class="stat-label">关注</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{stats.followers}}</text>
      <text class="stat-label">粉丝</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{stats.likes}}</text>
      <text class="stat-label">获赞</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-card">
    <view class="menu-item" bindtap="navigateToMyWorks">
      <view class="menu-icon">🎨</view>
      <text class="menu-text">我的作品</text>
      <view class="menu-arrow">></view>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="navigateToCollection">
      <view class="menu-icon">⭐</view>
      <text class="menu-text">我的收藏</text>
      <view class="menu-arrow">></view>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="navigateToFollowing">
      <view class="menu-icon">👥</view>
      <text class="menu-text">我的关注</text>
      <view class="menu-arrow">></view>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="navigateToSettings">
      <view class="menu-icon">⚙️</view>
      <text class="menu-text">设置</text>
      <view class="menu-arrow">></view>
    </view>
  </view>

  <!-- 关于我们 -->
  <view class="about-card">
    <view class="about-item">
      <text class="about-text">关于中华文脉·AI共创工坊</text>
      <view class="about-arrow">></view>
    </view>
    <view class="about-item">
      <text class="about-text">使用帮助</text>
      <view class="about-arrow">></view>
    </view>
    <view class="about-item">
      <text class="about-text">隐私政策</text>
      <view class="about-arrow">></view>
    </view>
    <view class="about-item">
      <text class="about-text">联系我们</text>
      <view class="about-arrow">></view>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">版本 1.0.0</text>
    <text class="copyright-text">© 2026 中华文脉·AI共创工坊</text>
  </view>
</view>